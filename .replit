modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8084
externalPort = 5173

[[ports]]
localPort = 8085
externalPort = 6000

[[ports]]
localPort = 22740
externalPort = 3000

[[ports]]
localPort = 22741
externalPort = 3002

[[ports]]
localPort = 22742
externalPort = 4200

[[ports]]
localPort = 22743
externalPort = 5000

[[ports]]
localPort = 22744
externalPort = 6800

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
